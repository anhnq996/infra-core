# ============================================
# Ticket Booking API Secret - EXAMPLE (safe to commit)
# ============================================
# Copy this file to secret-api.yaml on the server and replace DATABASE_URL.
# Do not commit the real secret-api.yaml.
#
# Example DATABASE_URL:
# postgres://ticket:ticket_password@postgres-postgresql.infra.svc.cluster.local:5432/ticket_booking?sslmode=disable
# ============================================
apiVersion: v1
kind: Secret
metadata:
  name: ticket-booking-api-secret
  namespace: ticket-booking
type: Opaque
stringData:
  DATABASE_URL: "postgres://ticket:REPLACE_PASSWORD@postgres-postgresql.infra.svc.cluster.local:5432/ticket_booking?sslmode=disable"
