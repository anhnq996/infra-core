# ============================================
# API Docs Secret - EXAMPLE (safe to commit)
# ============================================
# Hướng dẫn tạo secret thực trên server:
#
#   1. Copy file này:
#      cp secret.yaml.example secret.yaml
#
#   2. Tạo base64 cho từng giá trị thực:
#      echo -n "your_actual_value" | base64
#
#   3. Thay tất cả REPLACE_BASE64(...) bằng kết quả base64:
#      nano secret.yaml
#
#   4. Apply vào K3s:
#      kubectl apply -f secret.yaml
#
# ⚠️  KHÔNG commit secret.yaml lên Git!
# ============================================
apiVersion: v1
kind: Secret
metadata:
  name: api-docs-secret
  namespace: gotalk
type: Opaque
data:
  # ---- Basic Auth Username ----
  # Giá trị thực: admin
  # echo -n "admin" | base64
  AUTH_USERNAME: REPLACE_BASE64(AUTH_USERNAME)

  # ---- Basic Auth Password ----
  # Giá trị thực: your_secure_password
  # echo -n "your_secure_password" | base64
  AUTH_PASSWORD: REPLACE_BASE64(AUTH_PASSWORD)
